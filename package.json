{
  "name": "@spacecomx/oh-my-pi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Job-scoped extension/theme/skill launcher and config framework for the Pi coding agent (@earendil-works/pi-coding-agent)",
  "keywords": [
    "pi",
    "pi-package",
    "pi-coding-agent",
    "cli",
    "extensions",
    "agent"
  ],
  "homepage": "https://github.com/waynegibson/oh-my-pi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/waynegibson/oh-my-pi.git"
  },
  "bugs": {
    "url": "https://github.com/waynegibson/oh-my-pi/issues"
  },
  "author": "Wayne Gibson",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "cli",
    "extensions",
    "lib",
    "skills",
    "themes",
    "context",
    "jobs.json",
    "damage-control-rules.yaml",
    "AGENTS.md",
    "README.md",
    "LICENSE.md"
  ],
  "workspaces": [
    "extensions/*"
  ],
  "bin": {
    "ohmypi": "./cli/index.mjs"
  },
  "scripts": {
    "test": "vitest run"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.80.6",
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "@types/node": "^22.0.0",
    "vitest": "^4.1.10"
  }
}
